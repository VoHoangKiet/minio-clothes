# ==============================================================================
# MinIO Deployment Configuration Template
# Copy this file to '.env' and modify the values for your setup.
# ==============================================================================

# Admin Root Credentials (Must be minimum 8 characters)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadminpassword

# Port bindings on the host machine
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# Storage path on the host machine (relative or absolute)
# For Windows, you can use paths like ./data or specific drives.
MINIO_VOLUMES=./data

# Auto-created buckets on startup (separated by commas)
MINIO_DEFAULT_BUCKETS=public-bucket,private-bucket,temp-bucket

# Set public policy for these buckets (separated by commas, must be subset of MINIO_DEFAULT_BUCKETS)
MINIO_PUBLIC_BUCKETS=public-bucket
